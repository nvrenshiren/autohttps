{
  "endpoints": ["app"],
  "pipeline": ["product-manager", "architect", "designer", "developer", "qa"],
  "docs": {
    "prd": "docs/prd",
    "architecture": "docs/architecture",
    "design": "docs/design",
    "acceptance": "docs/acceptance"
  },
  "codeRoots": {},
