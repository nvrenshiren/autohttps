# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# ...but keep the embedded-SPA target dir present so `cargo build` (rust-embed) works on a
# fresh clone before `npm run build`. Track only the placeholder; real build products stay ignored.
!/frontend/dist/
/frontend/dist/*
!/frontend/dist/.gitkeep

# Runtime data (SQLite db + encrypted secrets + verification dirs — never commit)
/data/
.verify-*/

# Caches
.cache/
.eslintcache

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Environment (keep example files tracked)
.env
.env.local
.env.*.local
!.env.example

# Editors / IDE
.vscode/
.idea/
*.sw?

# OS junk
.DS_Store
Thumbs.db

# opcflow workbench (runtime orchestration state; SQLite WAL db)
.workbench/

# Rust build output (cargo workspace, added in later phases)
target/
