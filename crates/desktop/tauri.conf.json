{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "autohttps",
  "version": "0.1.0",
  "identifier": "com.autohttps.desktop",
  "build": {
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "autohttps",
        "url": "http://127.0.0.1:38443",
        "width": 800,
        "height": 600,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"]
  }
}
